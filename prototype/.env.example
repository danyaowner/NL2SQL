# Google Gemini API ключ (бесплатный tier)
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Модель Gemini (опционально, по умолчанию gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Путь к SQLite базе данных (опционально)
DB_PATH=test_company.db

# Порт сервера (опционально)
PORT=8000
